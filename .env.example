# Copy to .env and fill in. Do not commit .env.

# ---- SEC EDGAR ----
# Fair-access policy requires an identifying User-Agent with a contact address.
# Any reachable address works; does not have to be personal. Generic UAs get
# rate-limited or 403'd.
EDGAR_UA="Your Name <you@example.com>"
EDGAR_USER_AGENT="${EDGAR_UA}"

# ---- LLM ----
# ANTHROPIC_API_KEY is normally provided by ./secret-run (libsecret).
# Uncomment only if running without secret-run.
# ANTHROPIC_API_KEY=

# ---- Local vLLM (optional) ----
# Leave VLLM_URL unset to fall back to Anthropic Haiku for classifier and dev judge.
# Set to http://localhost:8001 when the vllm compose service is up (gpu profile).
# VLLM_URL=http://localhost:8001

# Optional HuggingFace token if pulling gated models. Not needed for Qwen 2.5 7B AWQ.
# HUGGING_FACE_HUB_TOKEN=

# ---- Data stores ----
POSTGRES_URL=postgresql://quorum:quorum@localhost:5432/quorum
QDRANT_URL=http://localhost:6333

# ---- Concurrency ----
# pg_pool_max default is (max_concurrent_requests * 4) + 5; override only if you know why.
# MAX_CONCURRENT_REQUESTS=4
# MAX_CONCURRENT_AXES_PER_REQUEST=4
# PG_POOL_MIN=10
# PG_POOL_MAX=21
